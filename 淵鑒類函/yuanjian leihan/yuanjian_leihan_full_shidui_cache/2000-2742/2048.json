{"page": {"section_bu": "服飾", "section_lei": "床襜", "category_path": "服飾/床襜"}, "explain_rows": [{"section": "床襜一", "text": "原释名曰床前帷曰襜襜垂也"}, {"section": "床襜一", "text": "增通俗文曰障床曰幨"}, {"section": "床襜二", "text": "原绿绮 晋东宫旧事曰皇太子纳妃有绿石绮绢裹床襜二"}, {"section": "床襜二", "text": "增青霞 苏轼诗曰梦中仇池 千仞岩便欲揽我青霞襜"}], "groups": []}